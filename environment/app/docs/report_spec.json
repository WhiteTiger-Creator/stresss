{
  "title": "Service Log Export — Diagnosis & Report Spec",
  "version": "3.3",
  "cli": {
    "path": "/app/log_audit.py",
    "subcommands": {
      "diagnose": {
        "usage": "python3 /app/log_audit.py diagnose --dossier PATH --report PATH",
        "defaults": {
          "dossier": "/app/incident/export_dossier.md",
          "report": "/app/output/diagnosis.json"
        },
        "must_include_all_allowed_ids": true,
        "must_not_include_repaired_keys": ["verified_summary", "output_paths"],
        "input_events_path": "/app/data/events.json"
      },
      "repair": {
        "usage": "python3 /app/log_audit.py repair --output-dir PATH",
        "defaults": {
          "output_dir": "/app/output"
        }
      }
    }
  },
  "diagnosis_report": {
    "required_keys_diagnosed": ["pipeline_status", "issues_found", "input_stats"],
    "required_keys_repaired": [
      "pipeline_status",
      "issues_found",
      "input_stats",
      "verified_summary",
      "output_paths"
    ],
    "pipeline_status_diagnosed": "diagnosed",
    "pipeline_status_repaired": "repaired",
    "issues_found_item": {
      "required_fields": ["id", "severity", "description", "resolution", "evidence"],
      "allowed_ids": [
        "wrong_timestamp_field",
        "severity_filter",
        "sort_order",
        "level_normalization",
        "dedupe_policy",
        "suppressed_filter"
      ],
      "evidence": {
        "required_fields": ["dossier_quote", "pipeline_evidence", "repair_action"],
        "pipeline_evidence_source": "/app/workflow/.export_report.original",
        "pipeline_evidence_format": "literal substring excerpt from frozen original workflow source",
        "dossier_quote_format": "verbatim excerpt from /app/incident/export_dossier.md (whitespace-normalized match)",
        "required_terms_by_issue": {
          "wrong_timestamp_field": {
            "dossier_quote": ["timestamp", "ts_ms"],
            "pipeline_evidence": ["event[\"timestamp\"]"],
            "repair_action": ["ts_ms"]
          },
          "severity_filter": {
            "dossier_quote": ["warn", "error"],
            "pipeline_evidence": ["level == \"error\""],
            "repair_action": ["warn"]
          },
          "sort_order": {
            "dossier_quote": ["ascending", "descending"],
            "pipeline_evidence": ["sort", "ts_ms"],
            "repair_action": ["reverse=True"]
          },
          "level_normalization": {
            "dossier_quote": ["WARN", "lowercase"],
            "pipeline_evidence": ["level"],
            "repair_action": [".lower("]
          },
          "dedupe_policy": {
            "dossier_quote": ["duplicate", "ts_ms"],
            "pipeline_evidence": ["for event in events"],
            "repair_action": ["dedupe"]
          },
          "suppressed_filter": {
            "dossier_quote": ["suppressed", "excluded"],
            "pipeline_evidence": ["suppressed"],
            "repair_action": ["suppressed"]
          }
        }
      }
    },
    "input_stats": {
      "required_fields": ["event_count", "unique_event_ids", "services"],
      "services_sort": "ascending alphabetical",
      "source_events_path": "/app/data/events.json"
    },
    "verified_summary": {
      "required_fields": [
        "schema_version",
        "raw_event_count",
        "unique_event_ids",
        "total_events",
        "level_counts",
        "services",
        "flagged_count",
        "suppressed_excluded_count"
      ]
    },
    "output_paths": {
      "summary_json": "<output-dir>/summary.json",
      "flagged_jsonl": "<output-dir>/flagged.jsonl",
      "service_matrix_json": "<output-dir>/service_matrix.json"
    }
  },
  "canonicalization": {
    "dedupe_by_id": "collapse duplicate event ids, keeping the row with the highest ts_ms",
    "level_normalization": "lowercase level strings before counting and flagging",
    "total_events": "count canonical deduped events (suppressed rows remain in totals)",
    "flagged_export": "include warn and error only, exclude suppressed=true, sort ts_ms descending"
  },
  "repair_audit": {
    "required_keys": [
      "patched_workflow",
      "processing_steps",
      "removed_tokens",
      "pre_repair",
      "post_repair"
    ],
    "processing_steps": [
      "normalize_level",
      "dedupe_by_id",
      "filter_suppressed",
      "build_flagged"
    ],
    "patched_workflow": "/app/workflow/export_report.py",
    "forbidden_executable_tokens": [
      "event[\"timestamp\"]",
      "level == \"error\""
    ],
    "removed_tokens_schema": {
      "description": "Map each forbidden_executable_tokens entry to a boolean (true when absent from patched executable code, excluding comments and docstrings)."
    },
    "pre_repair": {
      "required_fields": ["pipeline_source_sha256", "pipeline_tokens_present"],
      "capture_order": "before any write to export_report.py",
      "pipeline_tokens_present_schema": {
        "description": "Map each forbidden_executable_tokens entry to a boolean (true when present in frozen broken snapshot before repair)."
      }
    },
    "post_repair": {
      "required_fields": ["flagged_count", "rerun_flagged_count"]
    }
  },
  "workflow_repair": {
    "path": "/app/workflow/export_report.py",
    "cli_usage": "python3 /app/workflow/export_report.py --input PATH --output-dir PATH",
    "defaults": {
      "input": "/app/data/events.json",
      "output_dir": "/app/output"
    },
    "forbidden_executable_tokens": [
      "event[\"timestamp\"]",
      "level == \"error\""
    ],
    "required_executable_tokens": [
      ".lower(",
      "reverse=True"
    ],
    "token_check_scope": "executable code only (exclude comments and docstrings)"
  },
  "outputs": {
    "summary_json": {
      "schema_version": "service-log-report-v2",
      "level_counts_key_order": ["debug", "error", "info", "warn"]
    },
    "service_matrix_json": {
      "description": "Per-service level counts from canonical processed events.",
      "service_sort": "ascending alphabetical",
      "level_key_order": ["debug", "error", "info", "warn"]
    },
    "flagged_jsonl": {
      "required_fields": ["id", "ts_ms", "level", "service", "message"],
      "sort": "ts_ms descending",
      "levels_included": ["warn", "error"],
      "exclude_suppressed": true,
      "json_format": "compact (no space after colon)"
    }
  },
  "long_context": {
    "dossier_path": "/app/incident/export_dossier.md",
    "minimum_line_count": 500
  }
}
